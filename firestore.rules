rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================
    // IMPORTANT: This app uses custom authentication (username/
    // password stored in Firestore), NOT Firebase Auth. Therefore
    // request.auth is always null for client requests.
    //
    // For real security, migrate to Firebase Auth so that rules
    // can use request.auth.uid to scope access per user.
    //
    // These rules are BEST-EFFORT: they validate data shapes and
    // restrict destructive operations, but cannot enforce true
    // per-user authorization without Firebase Auth.
    // =========================================================

    // --- subs (user accounts) --------------------------------
    match /subs/{subId} {
      // Anyone can read (needed for login check)
      allow read: if true;

      // Allow create with required fields and types
      allow create: if request.resource.data.keys().hasAll([
                         'username', 'password', 'displayName',
                         'createdAt', 'active'
                       ])
                    && request.resource.data.username is string
                    && request.resource.data.password is string
                    && request.resource.data.displayName is string
                    && request.resource.data.active is bool;

      // Allow update but prevent removing critical fields
      allow update: if request.resource.data.keys().hasAll([
                         'username', 'password', 'displayName',
                         'createdAt', 'active'
                       ])
                    && request.resource.data.username is string
                    && request.resource.data.displayName is string
                    && request.resource.data.active is bool;

      // Prevent deletion of sub accounts
      allow delete: if false;
    }

    // --- payments --------------------------------------------
    match /payments/{paymentId} {
      allow read: if true;

      // Allow create with required fields and validation
      allow create: if request.resource.data.keys().hasAll([
                         'paidBy', 'subId', 'amount',
                         'category', 'createdAt', 'createdBy'
                       ])
                    && request.resource.data.paidBy is string
                    && request.resource.data.subId is string
                    && request.resource.data.amount is number
                    && request.resource.data.amount > 0
                    && request.resource.data.category is string
                    && request.resource.data.createdBy is string;

      // Allow update (e.g. corrections) but keep required fields
      allow update: if request.resource.data.keys().hasAll([
                         'paidBy', 'subId', 'amount',
                         'category', 'createdAt', 'createdBy'
                       ])
                    && request.resource.data.amount is number
                    && request.resource.data.amount > 0;

      // Prevent deletion of payment records
      allow delete: if false;
    }

    // --- fagTaxes (weekly invoices) ---------------------------
    match /fagTaxes/{taxId} {
      allow read: if true;

      // Allow create with required fields
      allow create: if request.resource.data.keys().hasAll([
                         'subId', 'username', 'displayName',
                         'weekStart', 'baseAmount', 'totalAmount',
                         'paid', 'createdAt'
                       ])
                    && request.resource.data.subId is string
                    && request.resource.data.username is string
                    && request.resource.data.baseAmount is number
                    && request.resource.data.totalAmount is number
                    && request.resource.data.paid is bool;

      // Allow update (e.g. marking as paid) but keep required fields
      allow update: if request.resource.data.keys().hasAll([
                         'subId', 'username', 'displayName',
                         'weekStart', 'baseAmount', 'totalAmount',
                         'paid', 'createdAt'
                       ])
                    && request.resource.data.paid is bool
                    && request.resource.data.totalAmount is number;

      // Prevent deletion of tax records
      allow delete: if false;
    }

    // --- sessions (login tracking) ---------------------------
    match /sessions/{sessionId} {
      allow read: if true;

      // Allow create with required fields
      allow create: if request.resource.data.keys().hasAll([
                         'subId', 'username', 'loginTime', 'active'
                       ])
                    && request.resource.data.subId is string
                    && request.resource.data.username is string
                    && request.resource.data.active is bool;

      // Allow update (e.g. heartbeat, marking inactive)
      allow update: if request.resource.data.keys().hasAll([
                         'subId', 'username', 'loginTime', 'active'
                       ])
                    && request.resource.data.active is bool;

      // Allow deletion of old sessions (cleanup)
      allow delete: if true;
    }

    // --- accountChecks ---------------------------------------
    match /accountChecks/{checkId} {
      allow read: if true;

      // Allow create with required fields
      allow create: if request.resource.data.keys().hasAll([
                         'subId', 'amount', 'createdAt'
                       ])
                    && request.resource.data.subId is string
                    && request.resource.data.amount is number
                    && request.resource.data.amount > 0;

      // Allow update but keep required fields
      allow update: if request.resource.data.keys().hasAll([
                         'subId', 'amount', 'createdAt'
                       ])
                    && request.resource.data.amount is number;

      // Prevent deletion of check records
      allow delete: if false;
    }

    // Deny access to any other collections by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
